# ──────────────────────────────────────────────
# Supabase Credentials
# Find these in your Supabase dashboard → Settings → API
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────
# Gmail Email (for sending your daily digest)
# Get an App Password at: myaccount.google.com → Security → App Passwords
# ──────────────────────────────────────────────
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
DIGEST_TO_EMAIL=your.email@gmail.com

# ──────────────────────────────────────────────
# ManyChat API (for syncing subscribers to CRM)
# Get your API key at: manychat.com → Settings → API
# ──────────────────────────────────────────────
MANYCHAT_API_KEY=your_page_id:your_api_key
